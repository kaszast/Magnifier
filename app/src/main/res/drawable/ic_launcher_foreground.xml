<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 1. Ambient Drop Shadow under the magnifier for depth (offset slightly bottom-right) -->
    <path
        android:pathData="M 48,29 A 19,19 0 1,1 47.99,29 Z"
        android:strokeWidth="6"
        android:strokeColor="#50000000" />
    <path
        android:pathData="M62,62 L82,82"
        android:strokeWidth="9"
        android:strokeColor="#50000000"
        android:strokeLineCap="round" />

    <!-- 2. Magnifier Handle with vibrant dark gradient finish -->
    <path
        android:pathData="M60,60 L80,80"
        android:strokeWidth="8"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="60"
                android:startY="60"
                android:endX="80"
                android:endY="80"
                android:type="linear">
                <item android:offset="0.0" android:color="#D0BCFF" />
                <item android:offset="0.5" android:color="#6650a4" />
                <item android:offset="1.0" android:color="#45123E" />
            </gradient>
        </aapt:attr>
    </path>
    
    <!-- 3. Metallic base connector ring on the handle -->
    <path
        android:pathData="M58,58 L62,62"
        android:strokeWidth="9"
        android:strokeLineCap="square"
        android:strokeColor="#EFB8C8" />

    <!-- 4. Iridescent Outer Rim / Bezel of the Lens -->
    <path
        android:pathData="M 46,27 A 19,19 0 1,1 45.99,27 Z"
        android:strokeWidth="5">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="27"
                android:startY="27"
                android:endX="65"
                android:endY="65"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFFFFF" />
                <item android:offset="0.3" android:color="#D0BCFF" />
                <item android:offset="0.7" android:color="#EFB8C8" />
                <item android:offset="1.0" android:color="#6650a4" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 5. Glass Lens Fill (Translucent cyan/purple tint) -->
    <path
        android:pathData="M 46,29 A 17,17 0 1,1 45.99,29 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="29"
                android:startY="29"
                android:endX="63"
                android:endY="63"
                android:type="linear">
                <item android:offset="0.0" android:color="#40D0BCFF" />
                <item android:offset="1.0" android:color="#15000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 6. Lens Light Reflection & Glisten (Top-left crescent) -->
    <path
        android:pathData="M 32.5,38.5 A 13.5,13.5 0 0,1 38.5,32.5"
        android:strokeWidth="2.5"
        android:strokeColor="#B2FFFFFF"
        android:strokeLineCap="round" />

    <!-- 7. Lens Light Reflection & Glisten (Bottom-right soft gleam) -->
    <path
        android:pathData="M 59.5,53.5 A 13.5,13.5 0 0,1 53.5,59.5"
        android:strokeWidth="1.5"
        android:strokeColor="#40FFFFFF"
        android:strokeLineCap="round" />

</vector>
